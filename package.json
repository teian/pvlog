{
  "name": "pvlog",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "backend:server": "cargo run-server",
    "backend:worker": "cargo run-worker",
    "lint": "eslint src/ui && stylelint 'src/ui/**/*.css'",
    "lint:eslint": "eslint src/ui",
    "lint:styles": "stylelint 'src/ui/**/*.css'",
    "openapi:compare": "node tests/contract/openapi/compare.mjs tests/fixtures/openapi/pvlog-v1.generated.yaml",
    "openapi:analytics": "node tests/contract/openapi/analytics-examples.mjs",
    "openapi:lint": "redocly lint --config .redocly.yaml openapi/pvlog-v1.yaml",
    "openapi:routes": "node tests/contract/openapi/route-coverage.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:ui": "vitest run --config vitest.config.ts",
    "test:smoke": "cargo smoke",
    "test:segment-format": "node tests/contract/segment-format.mjs",
    "test:structure": "node --test tests/contract/repository-structure/check.test.mjs && node tests/contract/repository-structure/check.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:compatibility-inventory": "node tests/compatibility/inventory-contract.mjs",
    "test:compatibility-conformance": "node tests/compatibility/conformance-contract.mjs",
    "test:webhook-consumer": "node tests/contract/webhook-consumer.mjs",
    "test:query-performance": "node tests/performance/chart-query-harness.mjs",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans": "5.2.10",
    "@fontsource-variable/noto-serif": "5.2.9",
    "@hookform/resolvers": "5.4.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.220.0",
    "@opentelemetry/instrumentation": "0.220.0",
    "@opentelemetry/instrumentation-document-load": "0.65.0",
    "@opentelemetry/instrumentation-fetch": "0.220.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@opentelemetry/sdk-trace-web": "2.9.0",
    "@opentelemetry/semantic-conventions": "1.43.0",
    "@scalar/api-reference-react": "0.9.54",
    "@tanstack/react-query": "5.101.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "i18next": "26.3.6",
    "i18next-browser-languagedetector": "8.2.1",
    "lucide-react": "1.24.0",
    "next-themes": "0.4.6",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "react-i18next": "17.0.9",
    "react-router": "8.2.0",
    "recharts": "3.8.0",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.61.1",
    "@redocly/cli": "2.38.0",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9.39.4",
    "eslint-plugin-boundaries": "7.0.2",
    "eslint-plugin-jsdoc": "63.0.13",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-unicorn": "60.0.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "shadcn": "4.13.0",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}
