{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pvlog.local/schemas/equipment-catalog-definitions-v1.schema.json",
  "title": "PVLog shared equipment catalog definitions v1",
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceName", "sourceReference"],
      "properties": {
        "sourceName": { "type": "string", "minLength": 1 },
        "sourceReference": {
          "type": "string",
          "format": "uri",
          "minLength": 1
        },
        "retrievedOn": { "type": ["string", "null"], "format": "date" }
      }
    },
    "mppt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trackerIndex", "stringInputCount"],
      "properties": {
        "trackerIndex": { "type": "integer", "minimum": 1 },
        "stringInputCount": { "type": "integer", "minimum": 1 },
        "maximumOperatingCurrentMilliamperes": {
          "type": "integer",
          "minimum": 1
        },
        "maximumShortCircuitCurrentMilliamperes": {
          "type": "integer",
          "minimum": 1
        },
        "minimumVoltageMillivolts": { "type": "integer", "minimum": 1 },
        "maximumVoltageMillivolts": { "type": "integer", "minimum": 1 }
      }
    },
    "inverter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "revision",
        "manufacturer",
        "model",
        "dc",
        "ac",
        "operational",
        "provenance"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "revision": { "type": "string", "minLength": 1 },
        "manufacturer": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "dc": {
          "type": "object",
          "required": ["totalStringInputCount", "mpptInputs"],
          "properties": {
            "topology": {
              "enum": [
                "transformerless",
                "high_frequency_transformer",
                "line_frequency_transformer",
                "microinverter",
                "hybrid"
              ]
            },
            "totalStringInputCount": { "type": "integer", "minimum": 1 },
            "maximumInputVoltageMillivolts": {
              "type": "integer",
              "minimum": 1
            },
            "startVoltageMillivolts": { "type": "integer", "minimum": 1 },
            "nominalInputVoltageMillivolts": {
              "type": "integer",
              "minimum": 1
            },
            "minimumMpptVoltageMillivolts": { "type": "integer", "minimum": 1 },
            "maximumMpptVoltageMillivolts": { "type": "integer", "minimum": 1 },
            "maximumInputCurrentMilliamperes": {
              "type": "integer",
              "minimum": 1
            },
            "maximumShortCircuitCurrentMilliamperes": {
              "type": "integer",
              "minimum": 1
            },
            "mpptInputs": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/mppt" }
            }
          }
        },
        "ac": {
          "type": "object",
          "required": ["phaseCount", "ratedActivePowerWatts"],
          "properties": {
            "phaseCount": { "type": "integer", "minimum": 1, "maximum": 3 },
            "nominalGridVoltageMillivolts": { "type": "integer", "minimum": 1 },
            "minimumGridVoltageMillivolts": { "type": "integer", "minimum": 1 },
            "maximumGridVoltageMillivolts": { "type": "integer", "minimum": 1 },
            "minimumGridFrequencyMillihertz": {
              "type": "integer",
              "minimum": 1
            },
            "maximumGridFrequencyMillihertz": {
              "type": "integer",
              "minimum": 1
            },
            "ratedActivePowerWatts": { "type": "integer", "minimum": 1 },
            "maximumActivePowerWatts": { "type": "integer", "minimum": 1 },
            "maximumApparentPowerVoltAmperes": {
              "type": "integer",
              "minimum": 1
            },
            "maximumOutputCurrentMilliamperes": {
              "type": "integer",
              "minimum": 1
            },
            "minimumPowerFactorBasisPoints": {
              "type": "integer",
              "minimum": -10000,
              "maximum": 10000
            },
            "maximumPowerFactorBasisPoints": {
              "type": "integer",
              "minimum": -10000,
              "maximum": 10000
            },
            "totalHarmonicDistortionBasisPoints": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10000
            }
          }
        },
        "operational": {
          "type": "object",
          "required": ["communicationInterfaces"],
          "properties": {
            "maximumEfficiencyBasisPoints": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10000
            },
            "europeanEfficiencyBasisPoints": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10000
            },
            "standbyConsumptionWatts": { "type": "integer", "minimum": 0 },
            "deratingStartMilliCelsius": { "type": "integer" },
            "ingressProtectionRating": { "type": "string" },
            "maximumAltitudeMetres": { "type": "integer", "minimum": 0 },
            "communicationInterfaces": {
              "type": "array",
              "items": { "type": "string" }
            },
            "weightGrams": { "type": "integer", "minimum": 1 }
          }
        },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "solarModule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "revision",
        "manufacturer",
        "model",
        "specification",
        "provenance"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "revision": { "type": "string", "minLength": 1 },
        "manufacturer": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "specification": {
          "type": "object",
          "required": [
            "cellTechnology",
            "bifacial",
            "peakPowerWatts",
            "openCircuitVoltageMillivolts",
            "maximumPowerVoltageMillivolts",
            "shortCircuitCurrentMilliamperes",
            "maximumPowerCurrentMilliamperes",
            "efficiencyBasisPoints",
            "shortCircuitCurrentTemperatureCoefficientPpmPerCelsius",
            "openCircuitVoltageTemperatureCoefficientPpmPerCelsius",
            "peakPowerTemperatureCoefficientPpmPerCelsius"
          ],
          "properties": {
            "cellTechnology": {
              "enum": [
                "monocrystalline",
                "polycrystalline",
                "n_type_monocrystalline",
                "p_type_monocrystalline",
                "heterojunction",
                "thin_film",
                "other"
              ]
            },
            "cellDescription": { "type": "string" },
            "bifacial": { "type": "boolean" },
            "bifacialityFactorBasisPoints": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10000
            },
            "bifacialityToleranceBasisPoints": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10000
            },
            "peakPowerWatts": { "type": "integer", "minimum": 1 },
            "openCircuitVoltageMillivolts": { "type": "integer", "minimum": 1 },
            "maximumPowerVoltageMillivolts": {
              "type": "integer",
              "minimum": 1
            },
            "shortCircuitCurrentMilliamperes": {
              "type": "integer",
              "minimum": 1
            },
            "maximumPowerCurrentMilliamperes": {
              "type": "integer",
              "minimum": 1
            },
            "efficiencyBasisPoints": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10000
            },
            "shortCircuitCurrentTemperatureCoefficientPpmPerCelsius": {
              "type": "integer"
            },
            "openCircuitVoltageTemperatureCoefficientPpmPerCelsius": {
              "type": "integer"
            },
            "peakPowerTemperatureCoefficientPpmPerCelsius": {
              "type": "integer"
            },
            "maximumSystemVoltageMillivolts": {
              "type": "integer",
              "minimum": 1
            },
            "operatingTemperature": {
              "type": "object",
              "required": ["minimumMilliCelsius", "maximumMilliCelsius"]
            },
            "maximumSeriesFuseMilliamperes": {
              "type": "integer",
              "minimum": 1
            },
            "maximumFrontStaticLoadPascals": {
              "type": "integer",
              "minimum": 1
            },
            "maximumRearStaticLoadPascals": { "type": "integer", "minimum": 1 },
            "dimensionsMillimetres": {
              "type": "object",
              "required": ["length", "width", "height"]
            },
            "weightGrams": { "type": "integer", "minimum": 1 }
          }
        },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    }
  }
}
