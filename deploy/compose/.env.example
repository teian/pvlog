# Use an immutable release tag. Do not use `latest` for an upgradeable installation.
PVLOG_IMAGE=pvlog:0.1.0

# Generate each value independently: openssl rand -hex 32
PVLOG_SESSION_SECRET=replace-with-at-least-32-random-bytes
PVLOG_CREDENTIAL_ENCRYPTION_KEY=replace-with-at-least-32-random-bytes

# Use HTTPS and a public hostname in an internet-facing installation.
PVLOG_PUBLIC_BASE_URL=https://pvlog.example.test
PVLOG_HTTP_PORT=8080
PVLOG_WORKER_INTERVAL_SECONDS=30

# Provider-neutral yield forecasting is opt-in. The credential value remains in
# the external secret manager; only its reference is passed to PVLog.
PVLOG_FORECASTING_ENABLED=false
PVLOG_FORECASTING_ADAPTER_ENDPOINT=https://weather-adapter.internal/v1/normalized
PVLOG_FORECASTING_CREDENTIAL_SECRET_REF=secret://weather/production
PVLOG_FORECASTING_POLL_INTERVAL_SECONDS=900
PVLOG_FORECASTING_HORIZON_HOURS=72
PVLOG_FORECASTING_MAXIMUM_STALE_AGE_SECONDS=21600
PVLOG_FORECASTING_MODEL_IDENTIFIER=pv-yield-v1
PVLOG_FORECASTING_MODEL_REVISION=1
PVLOG_FORECASTING_WORKING_RETENTION_DAYS=30
PVLOG_FORECASTING_WORKER_CONCURRENCY=2

# PostgreSQL profile only. Keep this file private after replacing the placeholder.
PVLOG_POSTGRES_DB=pvlog
PVLOG_POSTGRES_USER=pvlog
PVLOG_POSTGRES_PASSWORD=replace-with-a-long-random-password

# Optional provider-neutral connector configuration uses PVLOG_AUTH__CONNECTORS__<INDEX>__*
# values or a mounted pvlog.toml. Never put connector client secrets in a committed file.
