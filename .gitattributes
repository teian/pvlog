# Normalize repository text files across development platforms.
* text=auto eol=lf

# Source code and scripts
*.rs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sql text eol=lf
*.sh text eol=lf
Dockerfile* text eol=lf

# Configuration, schemas, and documentation
*.json text eol=lf
*.jsonc text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.svg text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env.example text eol=lf
.env.*.example text eol=lf

# Native Windows scripts retain their expected line endings.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Dependency lockfiles are machine-generated but remain reviewable text.
Cargo.lock linguist-generated=true
pnpm-lock.yaml linguist-generated=true

# Binary assets and archives
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.zip binary
*.gz binary
*.zst binary
*.sqlite binary
*.sqlite3 binary
*.db binary
