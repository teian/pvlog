# Optional local backend configuration. Copy to .env; never commit real secrets.
PVLOG_ENVIRONMENT=development
PVLOG_HTTP__BIND=127.0.0.1:18087
PVLOG_HTTP__PUBLIC_BASE_URL=http://localhost:18087
PVLOG_HTTP__SECURE_COOKIES=false

# Generate each value independently with: openssl rand -hex 32
PVLOG_SECURITY__SESSION_SECRET=replace-with-at-least-32-random-bytes
PVLOG_SECURITY__CREDENTIAL_ENCRYPTION_KEY=replace-with-at-least-32-random-bytes

PVLOG_DATABASE__BACKEND=sqlite
PVLOG_DATABASE__SQLITE__MANAGEMENT_PATH=data/management.sqlite3
PVLOG_DATABASE__SQLITE__ACCOUNTS_DIR=data/accounts

PVLOG_AUTH__LOCAL__ENABLED=true
PVLOG_AUTH__LOCAL__ALLOW_SELF_REGISTRATION=false
PVLOG_AUTH__LOCAL__REQUIRE_VERIFIED_EMAIL=true
